#!/bin/bash

set -euo pipefail

REPO_URL="${DEV_MAC_REPO_URL:-https://github.com/jfahrer/dev-mac.git}"
INSTALL_DIR="${DEV_MAC_DIR:-$HOME/.dev-mac}"

progress() {
  printf '\n==> %s\n' "$*"
}

if ! command -v git >/dev/null 2>&1; then
  progress "Git is unavailable; requesting the Xcode Command Line Tools"
  xcode-select --install 2>/dev/null || true
  printf '%s\n' \
    "Complete the installation in Apple's dialog, then run this command again."
  exit 1
fi

if [[ -e "$INSTALL_DIR" ]]; then
  if ! git -C "$INSTALL_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'error: %s exists but is not a Git checkout; leaving it untouched.\n' "$INSTALL_DIR" >&2
    exit 1
  fi

  progress "Using existing checkout at $INSTALL_DIR"
  if [[ -n "$(git -C "$INSTALL_DIR" status --porcelain)" ]]; then
    printf '%s\n' "Local changes detected; they will be preserved."
  fi
else
  progress "Cloning dev-mac into $INSTALL_DIR"
  git clone "$REPO_URL" "$INSTALL_DIR"
fi

exec "$INSTALL_DIR/script/bootstrap"
