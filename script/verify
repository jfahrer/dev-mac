#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
BASH_IT_DIR="${BASH_IT_DIR:-$HOME/.bash_it}"
failures=0

ok() { printf 'ok: %s\n' "$*"; }
fail() { printf 'missing: %s\n' "$*" >&2; failures=$((failures + 1)); }
warn() { printf 'warning: %s\n' "$*" >&2; }

read_symbolic_hotkey_value() {
  local key_path="$1"
  defaults export com.apple.symbolichotkeys - 2>/dev/null |
    plutil -extract "$key_path" raw -o - - 2>/dev/null
}

verify_internal_caps_lock() {
  local device vendor_id product_id preference_key key_path mapping
  device="$(hidutil list --ndjson --matching keyboard 2>/dev/null |
    grep -m 1 '"Built-In":true' || true)"
  if [[ -z "$device" ]]; then
    return 0
  fi
  vendor_id="$(printf '%s\n' "$device" | plutil -extract VendorID raw -o - -)"
  product_id="$(printf '%s\n' "$device" | plutil -extract ProductID raw -o - -)"
  preference_key="com.apple.keyboard.modifiermapping.${vendor_id}-${product_id}-0"
  key_path="${preference_key//./\\.}"
  mapping="$(defaults -currentHost export NSGlobalDomain - 2>/dev/null |
    plutil -extract "$key_path" json -o - - 2>/dev/null || true)"
  [[ "$mapping" == *'"HIDKeyboardModifierMappingDst":30064771300,"HIDKeyboardModifierMappingSrc":30064771129'* ]]
}

if command -v brew >/dev/null 2>&1; then
  ok "Homebrew"
  if brew bundle check --file "$REPO_ROOT/Brewfile" >/dev/null 2>&1; then
    ok "every Brewfile dependency"
  else
    fail "one or more Brewfile dependencies (run: brew bundle --file '$REPO_ROOT/Brewfile')"
    brew bundle check --verbose --file "$REPO_ROOT/Brewfile" || true
  fi
else
  fail "Homebrew"
fi

account_name="$(id -un)"
login_shell="$(dscacheutil -q user -a name "$account_name" |
  awk '$1 == "shell:" { print $2; exit }')"
if [[ "$login_shell" == "/bin/bash" ]]; then
  ok "default login shell is /bin/bash"
else
  fail "default login shell /bin/bash (run: chsh -s /bin/bash)"
fi

if git -C "$BASH_IT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1 &&
   [[ -r "$BASH_IT_DIR/bash_it.sh" ]]; then
  ok "Bash-it checkout"
else
  fail "Bash-it checkout at $BASH_IT_DIR"
fi

bash_it_login_check="$(/bin/bash -lic \
  'if [[ -n ${BASH_IT:-} && -r ${BASH_IT}/bash_it.sh ]]; then printf __DEV_MAC_BASH_IT_ACTIVE__; fi' \
  2>/dev/null || true)"
if [[ "$bash_it_login_check" == *"__DEV_MAC_BASH_IT_ACTIVE__"* ]]; then
  ok "Bash-it activation in the login shell"
else
  fail "Bash-it activation (the dotfiles-managed Bash startup must source \$BASH_IT/bash_it.sh)"
fi

if git -C "$DOTFILES_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  ok "dotfiles Git checkout"
else
  fail "dotfiles Git checkout at $DOTFILES_DIR"
fi

linked_dotfile=""
while IFS= read -r candidate; do
  target="$(readlink "$candidate" 2>/dev/null || true)"
  if [[ "$target" == "$DOTFILES_DIR"/* || "$target" == *"$(basename "$DOTFILES_DIR")/"* ]]; then
    linked_dotfile="$candidate"
    break
  fi
done < <(find "$HOME" -maxdepth 3 -type l 2>/dev/null)
if [[ -n "$linked_dotfile" ]]; then
  ok "rcm-managed dotfile link ($linked_dotfile)"
else
  fail "a representative symlink into $DOTFILES_DIR (rerun its script/setup)"
fi

mise_config="$HOME/.config/mise/config.toml"
if command -v mise >/dev/null 2>&1 && [[ -f "$mise_config" ]] &&
   mise config ls --no-header 2>/dev/null | grep -Fq ".config/mise/config.toml"; then
  ok "mise discovers $mise_config"
else
  fail "mise discovery of $mise_config"
fi

dock_ok=true
if ! command -v dockutil >/dev/null 2>&1; then
  dock_ok=false
else
  for dock_item in Maps Mail Music Pages Numbers TV Keynote Phone Games; do
    if dockutil --find "$dock_item" >/dev/null 2>&1; then
      dock_ok=false
    fi
  done
  if ! dockutil --find "Brave Browser" >/dev/null 2>&1; then
    dock_ok=false
  fi
fi
if [[ "$dock_ok" == "true" ]]; then
  ok "Brave Browser present and unwanted applications removed from the Dock"
else
  fail "Dock cleanup or dockutil (rerun script/macos-defaults)"
fi

if verify_internal_caps_lock; then
  ok "internal-keyboard Caps Lock mapped to Control"
else
  warn "persistent internal-keyboard Caps Lock-to-Control mapping is unresolved; configure it in System Settings"
fi

if sudo grep -Eq '^[[:space:]]*auth[[:space:]]+sufficient[[:space:]]+pam_tid\.so([[:space:]]|$)' /etc/pam.d/sudo_local 2>/dev/null; then
  ok "Touch ID for sudo"
else
  fail "active Touch ID line in /etc/pam.d/sudo_local"
fi

if [[ "$(defaults read com.apple.screensaver askForPassword 2>/dev/null || true)" == "1" &&
      "$(defaults read com.apple.screensaver askForPasswordDelay 2>/dev/null || true)" == "0" ]]; then
  ok "immediate screen-lock password"
else
  fail "immediate screen-lock password"
fi

firewall_status="$(sudo /usr/libexec/ApplicationFirewall/socketfilterfw --getglobalstate 2>/dev/null || true)"
if [[ "$firewall_status" == *"enabled"* ]]; then ok "application firewall"; else fail "application firewall"; fi

recovery_message="$(sudo defaults read /Library/Preferences/com.apple.loginwindow LoginwindowText 2>/dev/null || true)"
if [[ "$recovery_message" == "Found this computer? Please contact "* && "$recovery_message" == *"." ]]; then
  ok "login-window recovery message"
else
  fail "login-window recovery message"
fi

filevault_status="$(sudo fdesetup status 2>/dev/null || true)"
if { [[ "$filevault_status" == *"FileVault is On"* ]] || [[ "$filevault_status" == *"Encryption in progress"* ]]; } &&
   [[ "$(sudo fdesetup haspersonalrecoverykey 2>/dev/null || true)" == "true" ]]; then
  ok "FileVault and personal recovery key"
else
  fail "FileVault enabled/in progress with a personal recovery key"
fi

defaults_ok=true
[[ "$(defaults read NSGlobalDomain com.apple.keyboard.fnState 2>/dev/null || true)" == "1" ]] || defaults_ok=false
[[ "$(defaults read NSGlobalDomain KeyRepeat 2>/dev/null || true)" == "1" ]] || defaults_ok=false
[[ "$(defaults read NSGlobalDomain AppleKeyboardUIMode 2>/dev/null || true)" == "3" ]] || defaults_ok=false
[[ "$(defaults read com.apple.TimeMachine DoNotOfferNewDisksForBackup 2>/dev/null || true)" == "1" ]] || defaults_ok=false
[[ "$(defaults read com.apple.menuextra.clock DateFormat 2>/dev/null || true)" == "EEE MMM d  h:mm:ss a" ]] || defaults_ok=false
[[ "$(sudo defaults read /Library/Preferences/com.apple.loginwindow showInputMenu 2>/dev/null || true)" == "1" ]] || defaults_ok=false
if [[ "$defaults_ok" == "true" ]]; then
  ok "required macOS defaults"
else
  fail "one or more required macOS defaults (rerun script/macos-defaults)"
fi

shortcuts_ok=true
[[ "$(read_symbolic_hotkey_value 'AppleSymbolicHotKeys.64.enabled' || true)" == "true" ]] || shortcuts_ok=false
[[ "$(read_symbolic_hotkey_value 'AppleSymbolicHotKeys.64.value.parameters.0' || true)" == "32" ]] || shortcuts_ok=false
[[ "$(read_symbolic_hotkey_value 'AppleSymbolicHotKeys.64.value.parameters.1' || true)" == "49" ]] || shortcuts_ok=false
[[ "$(read_symbolic_hotkey_value 'AppleSymbolicHotKeys.64.value.parameters.2' || true)" == "786432" ]] || shortcuts_ok=false
[[ "$(read_symbolic_hotkey_value 'AppleSymbolicHotKeys.32.enabled' || true)" == "false" ]] || shortcuts_ok=false
[[ "$(read_symbolic_hotkey_value 'AppleSymbolicHotKeys.33.enabled' || true)" == "false" ]] || shortcuts_ok=false
if [[ "$shortcuts_ok" == "true" ]]; then
  ok "Spotlight and Mission Control shortcuts"
else
  warn "Spotlight or Mission Control shortcuts are unresolved; configure them in System Settings"
fi

updates="$(softwareupdate --list 2>&1 || true)"
if [[ "$updates" == *"No new software available"* ]]; then
  ok "no pending macOS updates"
else
  fail "pending macOS updates (review: softwareupdate --list)"
fi

if ((failures > 0)); then
  printf '\nVerification failed with %d missing outcome(s).\n' "$failures" >&2
  exit 1
fi
printf '\nAll required outcomes verified.\n'
